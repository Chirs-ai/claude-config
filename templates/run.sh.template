#!/bin/bash
# 服务管理脚本 - 支持 start/stop/restart/status/logs
#
# 使用方法:
#   ./run.sh start      启动服务
#   ./run.sh stop       停止服务
#   ./run.sh restart    重启服务
#   ./run.sh status     查看状态
#   ./run.sh logs       查看实时日志
#
# ============ 按项目需求修改以下配置 ============

# 启动命令：替换为你的应用入口文件
APP_ENTRY="app.py"

# Python 环境类型：conda 或 venv
ENV_TYPE="conda"

# conda 环境名（ENV_TYPE=conda 时生效）
CONDA_ENV="${CONDA_ENV:-py312}"

# venv 路径（ENV_TYPE=venv 时生效）
VENV_DIR="venv"

# ============ 以下内容通常不需要修改 ============

APP_DIR="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$APP_DIR/app.pid"
LOG_FILE="$APP_DIR/app.log"

# 颜色
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
info()  { echo -e "${GREEN}[INFO]${NC} $1"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

# 激活 Python 环境
ensure_env() {
    case "$ENV_TYPE" in
        conda)
            if [[ "$CONDA_DEFAULT_ENV" == "$CONDA_ENV" ]]; then
                return 0
            fi
            if command -v conda &>/dev/null; then
                eval "$(conda shell.bash hook 2>/dev/null)"
            elif [ -f "$HOME/miniconda3/etc/profile.d/conda.sh" ]; then
                source "$HOME/miniconda3/etc/profile.d/conda.sh"
            elif [ -f "$HOME/anaconda3/etc/profile.d/conda.sh" ]; then
                source "$HOME/anaconda3/etc/profile.d/conda.sh"
            else
                error "未找到 conda，请先安装或手动激活环境: conda activate $CONDA_ENV"
                exit 1
            fi
            conda activate "$CONDA_ENV" 2>/dev/null || {
                error "无法激活 conda 环境 '$CONDA_ENV'，请确认环境存在: conda env list"
                exit 1
            }
            info "已激活 conda 环境: $CONDA_ENV"
            ;;
        venv)
            if [ ! -d "$APP_DIR/$VENV_DIR" ]; then
                error "虚拟环境 $VENV_DIR 不存在，请先创建: python3 -m venv $VENV_DIR"
                exit 1
            fi
            source "$APP_DIR/$VENV_DIR/bin/activate"
            info "已激活 venv 环境: $VENV_DIR"
            ;;
        *)
            error "未知的环境类型: $ENV_TYPE（支持 conda 或 venv）"
            exit 1
            ;;
    esac
}

get_pid() {
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        cat "$PID_FILE"
    else
        pgrep -f "python $APP_ENTRY" 2>/dev/null | head -1
    fi
}

do_start() {
    local pid
    pid=$(get_pid)
    if [ -n "$pid" ]; then
        warn "服务已在运行 (PID: $pid)"
        return 0
    fi
    ensure_env
    cd "$APP_DIR"
    nohup python "$APP_ENTRY" >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    sleep 2
    if kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        info "服务启动成功 (PID: $(cat "$PID_FILE"))"
    else
        error "服务启动失败，请检查日志: tail -50 $LOG_FILE"
        rm -f "$PID_FILE"
        exit 1
    fi
}

do_stop() {
    local pid
    pid=$(get_pid)
    if [ -z "$pid" ]; then
        warn "服务未在运行"
        return 0
    fi
    kill "$pid" 2>/dev/null
    sleep 2
    if kill -0 "$pid" 2>/dev/null; then
        warn "进程未退出，强制终止..."
        kill -9 "$pid" 2>/dev/null
    fi
    rm -f "$PID_FILE"
    info "服务已停止"
}

do_status() {
    local pid
    pid=$(get_pid)
    if [ -n "$pid" ]; then
        info "服务运行中 (PID: $pid)"
        ps -p "$pid" -o pid,user,%cpu,%mem,etime,cmd --no-headers
    else
        warn "服务未运行"
    fi
}

case "${1:-}" in
    start)   do_start ;;
    stop)    do_stop ;;
    restart) do_stop; do_start ;;
    status)  do_status ;;
    logs)    tail -f "$LOG_FILE" ;;
    *)
        echo "用法: $0 {start|stop|restart|status|logs}"
        ;;
esac
